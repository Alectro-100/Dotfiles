### Terminal file explorer
function y() {
    local tmp="$(mktemp -t "yazi-cwd.XXXXXX")" cwd
    /usr/bin/yazi "$@" --cwd-file="$tmp"
    if cwd="$(command cat -- "$tmp")" && [ -n "$cwd" ] && [ "$cwd" != "$PWD" ]; then
        builtin cd -- "$cwd"
    fi
    rm -f -- "$tmp"
}

